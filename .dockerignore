# Project-specific exclusions
# Exclude nginx config and logs (not needed in API container)
nginx/

# Exclude frontend (not needed in API container)
view/

# Exclude ChromaDB data (mounted as volume)
chromadb/

# Exclude test files (not needed in production)
tests/

# Exclude database (mounted as volume)
data/db/

# Keep requirements and source code
!requirements.txt
!main.py
!core/
!data/
!rag/
!utils/
!logconf.yml
!pytest.ini
!README.md

# Allow data scripts but exclude DB files
data/**/*.db
data/**/*.sqlite
data/**/*.sqlite3

